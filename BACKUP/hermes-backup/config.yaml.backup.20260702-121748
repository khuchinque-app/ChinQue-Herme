model:
  provider: nous
  base_url: https://inference-api.nousresearch.com/v1
  default: moonshotai/kimi-k2.6
agent:
  max_turns: 150
  disabled_toolsets:
    - browser
    - clarify
    - computer_use
    - cronjob
    - delegation
    - discord
    - discord_admin
    - feishu_doc
    - feishu_drive
    - homeassistant
    - image_gen
    - kanban
    - memory
    - moa
    - session_search
    - spotify
    - todo
    - tts
    - video
    - video_gen
    - vision
    - x_search
    - yuanbao
terminal:
  cwd: /home/khuchinque/hermes-pipeline
web:
  backend: firecrawl
  use_gateway: true
browser:
  cloud_provider: browser-use
  use_gateway: true
display:
  tool_progress: all
tts:
  provider: openai
  use_gateway: true
stt:
  provider: openai
  use_gateway: true
_config_version: 32
session_reset:
  mode: none
image_gen:
  use_gateway: true
video_gen:
  provider: fal
  use_gateway: true
onboarding:
  seen:
    busy_input_prompt: true
    tool_progress_prompt: true
memory:
  provider: honcho
gateway:
  multiplex_profiles: false
